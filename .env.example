# LegalRo — environment variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# ── LLM ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── OCR (needed for scanned / facsimile PDFs) ────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key

# ── Alternative OCR (optional) ───────────────────────────────────────────────
# LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key

# ── CLI remote client ─────────────────────────────────────────────────────────
# Set these to use the CLI as a thin client instead of running locally.
LEGALRO_API_URL=https://your-space.hf.space
LEGALRO_API_TOKEN=your_api_token_here   # must match API_TOKEN in HF Space secrets

# HF_TOKEN is required only for PRIVATE HF Spaces (authenticates with HF proxy).
# Generate a read token at: huggingface.co/settings/tokens
# HF_TOKEN=hf_your_read_token_here

# ── API server token (protect your HF Space endpoints) ───────────────────────
# Set the same value as API_TOKEN in your HF Space secrets.
API_TOKEN=your_api_token_here
